[
  {
    "type": "checkbox",
    "label": "Enable AI",
    "property": "browser.ml.enabled",
    "force": true,
    "defaultValue": true
  },
  {
    "type": "dropdown",
    "label": "Sorting Engine",
    "property": "extension.zen-tidy-tabs.provider",
    "defaultValue": "firefox-local",
    "placeholder": false,
    "options": [
      {
        "value": "firefox-local",
        "label": "Firefox Local AI"
      },
      {
        "value": "gemini",
        "label": "Google Gemini"
      },
      {
        "value": "openrouter",
        "label": "OpenRouter"
      }
    ]
  },
  {
    "type": "string",
    "label": "Gemini API Key",
    "property": "extension.zen-tidy-tabs.gemini-api-key",
    "placeholder": "AIza..."
  },
  {
    "type": "string",
    "label": "OpenRouter API Key",
    "property": "extension.zen-tidy-tabs.openrouter-api-key",
    "placeholder": "sk-or-v1-..."
  },
  {
    "type": "string",
    "label": "OpenRouter Model Name",
    "property": "extension.zen-tidy-tabs.openrouter-model",
    "placeholder": "google/gemma-4-27b-it:free"
  }
]
